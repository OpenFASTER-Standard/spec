		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="GermanTaxNumberType">
		<xs:annotation>
			<xs:documentation xml:lang="en">German tax number (Steuernummer): 10 to 13 digits.</xs:documentation>
			<xs:documentation xml:lang="de">Deutsche Steuernummer: 10 bis 13 Ziffern.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[0-9]{13}"/>
		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="LEIISO17442Type">
		<xs:annotation>
			<xs:documentation xml:lang="en">Legal Entity Identifier (LEI) according to ISO 17442: exactly 20 alphanumeric characters.</xs:documentation>
			<xs:documentation xml:lang="de">Legal Entity Identifier (LEI) gemäß ISO 17442: genau 20 alphanumerische Zeichen.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
