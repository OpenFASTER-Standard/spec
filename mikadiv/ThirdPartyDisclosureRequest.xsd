	<xs:simpleType name="DateOfBirthType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Date of birth. Partially unknown dates are permitted: yyyy-mm-00 (unknown day), yyyy-00-00 (unknown month and day), 0000-00-00 (entirely unknown).</xs:documentation>
			<xs:documentation xml:lang="de">Geburtsdatum. Teilweise unbekannte Daten sind zulässig: yyyy-mm-00 (unbekannter Tag), yyyy-00-00 (unbekannter Monat und Tag), 0000-00-00 (vollständig unbekannt).</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[0-9]{4}-[0-9]{2}-[0-9]{2}"/>
		</xs:restriction>
	</xs:simpleType>

    <xs:simpleType name="NameType">
        <xs:annotation>
            <xs:documentation xml:lang="en">Basetype for other name types.</xs:documentation>
            <xs:documentation xml:lang="de">Basistyp für andere Name Typen.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:pattern value="([^\n\r\t])*"/>
        </xs:restriction>
    </xs:simpleType>
    
