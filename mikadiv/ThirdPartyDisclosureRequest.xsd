    <xs:complexType name="ReceiptsAndDeliveriesAllType">
        <xs:annotation>
            <xs:documentation xml:lang="en">List of acquisitions and disposals between 12 month before payment and 47 days after payment. No FiFo calculation applied.</xs:documentation>
            <xs:documentation xml:lang="de">Liste von Anschaffungen und Veräußerungen zwischen 12 Monaten vor Zahlung und 47 Tagen nach Zahlung. Keine FiFo Berechnung angewendet.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="OpeningBalance" type="Decimal15Dot4Type" minOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Balance before 12 month.</xs:documentation>
                    <xs:documentation xml:lang="de">Bestand vor 12 Monaten.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="OpeningBalanceDate" type="xs:dateTime" minOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Date of the initial holdings evaluation.</xs:documentation>
                    <xs:documentation xml:lang="de">Datum des ermittelten Eingangsbestands.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:sequence>
                <xs:element name="Transaction" type="RawTransactionType" minOccurs="0" maxOccurs="unbounded" />
            </xs:sequence>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="RawTransactionType">
        <xs:annotation>
            <xs:documentation xml:lang="en">Deliver trades are sales, book-entry transfers (delivery out), securities lending transactions and repurchase trades (repo). .</xs:documentation>
            <xs:documentation xml:lang="de">Auslieferungstransaktionen sind Verkäufe, Übertragungen im Effektengiroverkehr (Auslieferungen), Wertpapierleihen sowie Wertpapierpensionsgeschäfte (Repo).</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Nominal" type="Decimal15Dot4Type" minOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Number of shares / nominal value on which the transaction is based (= per deliver trade, if the trade date is within 47 calendar days after the date of the annual shareholders' meeting (AGM date; day of the dividend distribution resolution).</xs:documentation>
                    <xs:documentation xml:lang="de">Anzahl der Aktien / Nennwert, auf den die Transaktion entfällt (je Auslieferungstransaktion, sofern der Handelstag innerhalb von 47 Kalendertagen nach dem Tag der Hauptversammlung – HV-Tag, Tag des Gewinnverwendungsbeschlusses – liegt).</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TradeDate" type="xs:date" minOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Trade Date.</xs:documentation>
                    <xs:documentation xml:lang="de">Handelstag.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="IntraDaySequence" type="xs:integer" minOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Sortable number, for the case that more than one transaction per trade date is delivered.</xs:documentation>
                    <xs:documentation xml:lang="de">Sortierbare Zahl für den Fall dass mehr als eine Transaktion an einem Handelstag geliefert wird.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TransactionType" type="RawTransactionTypeType" minOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Category of securities trading transacted.</xs:documentation>
                    <xs:documentation xml:lang="de">Art des getätigten Wertpapiergeschäfts.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ContractualSettlementDate" type="xs:date" minOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Agreed settlement date (Contractual settlement date).</xs:documentation>
                    <xs:documentation xml:lang="de">Vereinbarter Erfüllungstag (vertragliches Erfüllungsdatum).</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="ActualSettlementDate" type="xs:date" minOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Actual settlement date.</xs:documentation>
                    <xs:documentation xml:lang="de">Tatsächlicher Erfüllungstag.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="COAF" type="COAFType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Corporate action event reference (COAF). Must be provided, if dividend or interest transaction type.</xs:documentation>
                    <xs:documentation xml:lang="de">Corporate action event reference (COAF). Muss geliefert werden für dividend oder interest Transaktionstypen.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="TransactionReference" type="Name45Type" use="optional">
            <xs:annotation>
                <xs:documentation xml:lang="en">Transaction reference beneficial owner/customer .</xs:documentation>
                <xs:documentation xml:lang="de">Transaktionsreferenz des wirtschaftlich Berechtigten bzw. Kunden.</xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="TransactionReferencePayingAgent" type="Name45Type" use="optional">
            <xs:annotation>
                <xs:documentation xml:lang="en">Transaction reference German Paying Agent.</xs:documentation>
                <xs:documentation xml:lang="de">Transaktionsreferenz der inländischen auszahlenden Stelle.</xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    
	<xs:complexType name="CustodyChainType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Ordered list of institutions in the custody chain.</xs:documentation>
			<xs:documentation xml:lang="de">Geordnete Liste von Finanzinstituten in der Verwahrkette.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
            <xs:element name="CustodyEntry" minOccurs="0" maxOccurs="20">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Declares a custody in the chain.</xs:documentation>
                    <xs:documentation xml:lang="de">Deklariert eine Verwahrung in der Verwahrkette.</xs:documentation>
                </xs:annotation>
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="NumberInChain" type="xs:unsignedByte" minOccurs="1">
                            <xs:annotation>
                                <xs:documentation xml:lang="en">Order in the custody chain. 1 is the custodian with the securities account for the beneficiary of person holding in favor of the beneficiary on its account.</xs:documentation>
                                <xs:documentation xml:lang="de">Reihenfolge in der Verwahrkette. 1 ist die Depotführende Bank für den wirtschaftlichen Eigentümer oder den vertretenden Account-Eigentümer.</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="NameOfIntermediary" type="Name256Type" minOccurs="1">
                            <xs:annotation>
                                <xs:documentation xml:lang="en">Name of the depository/(sub-)custodian.</xs:documentation>
                                <xs:documentation xml:lang="de">Bezeichnung der Verwahrstelle bzw. Unterverwahrstelle.</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="Address" type="CustodyEntryAddressType" minOccurs="1" />
                        <xs:element name="TaxIdentification" type="CustodianTaxIdentificationType" minOccurs="1"/>
                        <xs:element name="AccountNumber" type="Name200Type" minOccurs="1">
                            <xs:annotation>
                                <xs:documentation xml:lang="en">Account number or securities account in which the securities are held by the customer of an intermediary (i.e. the beneficiary or the person holding the position of the beneficiary on its account or the preceding intermediary).</xs:documentation>
                                <xs:documentation xml:lang="de">Konto- bzw. Depotnummer, unter der die Wertpapiere für den Kunden eines Intermediärs geführt werden (d. h. für den wirtschaftlich Berechtigten, die für ihn die Position haltende Person oder den vorgelagerten Intermediär).</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="AccountType" type="AccountTypeType" minOccurs="1">
                            <xs:annotation>
                                <xs:documentation xml:lang="en">Account type.</xs:documentation>
                                <xs:documentation xml:lang="de">Kontoart.</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="NominalInAccount" type="Decimal15Dot4Type" minOccurs="1">
                            <xs:annotation>
                                <xs:documentation xml:lang="en">Number of shares / nominal value held in the account of the respective account holder (i.e. the tax voucher person or of the third party holding the securities in the name of the tax voucher person or the preceding intermediary) (Number of shares held in the account).</xs:documentation>
                                <xs:documentation xml:lang="de">Anzahl der Aktien / Nennwert, der im Konto des jeweiligen Kontoinhabers (d. h. der bescheinigungsberechtigten Person, des die Wertpapiere für die bescheinigungsberechtigte Person haltenden Dritten oder des vorgelagerten Intermediärs) gehalten wird (im Konto gehaltene Stückzahl).</xs:documentation>
                            </xs:annotation>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
	</xs:complexType>

