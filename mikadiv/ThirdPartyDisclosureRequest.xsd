	<xs:simpleType name="BZSTTaxNumberType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Special German tax number assigned by the Federal Central Tax Authority (BZSt) to non-German Special-Investment Funds under Section 30 GITA.</xs:documentation>
			<xs:documentation xml:lang="de">Spezielle deutsche Steuernummer des Bundeszentralamts für Steuern für ausländische Spezial-Investmentfonds nach § 30 InvStG.</xs:documentation>
		</xs:annotation>
        <xs:restriction base="xs:string">
