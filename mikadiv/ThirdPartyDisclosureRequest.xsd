		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="GermanBusinessIdType">
		<xs:annotation>
			<xs:documentation xml:lang="en">German business identification number (Wirtschafts-Identifikationsnummer): 13 digits without hyphen before the differentiating element.</xs:documentation>
			<xs:documentation xml:lang="de">Deutsche Wirtschafts-Identifikationsnummer: 13 Ziffern, ohne Bindestrich vor dem Unterscheidungsmerkmal.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
