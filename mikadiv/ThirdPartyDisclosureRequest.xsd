	</xs:simpleType>

	<xs:simpleType name="SwiftBICCodeType">
		<xs:annotation>
			<xs:documentation xml:lang="en">BIC (Bank Identifier Code): 8 or 11 alphanumeric characters per ISO 9362.</xs:documentation>
			<xs:documentation xml:lang="de">BIC (Bank Identifier Code): 8 oder 11 alphanumerische Zeichen gemäß ISO 9362.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}([A-Z0-9]{3})?"/>
		</xs:restriction>
	</xs:simpleType>


	<xs:simpleType name="Name16Type">
		<xs:annotation>
