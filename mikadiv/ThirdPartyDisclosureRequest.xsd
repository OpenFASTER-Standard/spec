	<xs:simpleType name="GermanTaxIdType">
		<xs:annotation>
			<xs:documentation xml:lang="en">German tax identification number (IdNr): exactly 11 digits.</xs:documentation>
			<xs:documentation xml:lang="de">Deutsche steuerliche Identifikationsnummer (IdNr.): genau 11 Ziffern.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
