	<xs:simpleType name="ISINISO6166Type">
		<xs:annotation>
			<xs:documentation xml:lang="en">International Securities Identification Number (ISIN) according to ISO 6166: 2 uppercase letters followed by 10 alphanumeric characters.</xs:documentation>
			<xs:documentation xml:lang="de">International Securities Identification Number (ISIN) gemäß ISO 6166: 2 Großbuchstaben gefolgt von 10 alphanumerischen Zeichen.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:pattern value="[A-Z]{2}[A-Z0-9]{10}"/>
		</xs:restriction>
	</xs:simpleType>
    
    <xs:simpleType name="COAFType">
        <xs:annotation>
            <xs:documentation xml:lang="en">Corporate Action Event Reference (COAF).</xs:documentation>
            <xs:documentation xml:lang="de">Corporate Action Event Reference (COAF).</xs:documentation>
        </xs:annotation>
        <xs:restriction base="NameType">
            <xs:maxLength value="16"/>
        </xs:restriction>
    </xs:simpleType>
    
    <xs:simpleType name="TypeOfSecurityType">
        <xs:annotation>
            <xs:documentation xml:lang="en">Type of the security generating the capital income. Determines the category of the financial instrument held in the custodian account.</xs:documentation>
            <xs:documentation xml:lang="de">Art des Wertpapiers, das den Kapitalertrag erzeugt. Bestimmt die Kategorie des im Depot gehaltenen Finanzinstruments.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Equity">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Equity security (share). Represents ownership in a corporation and entitles the holder to dividends and voting rights. Capital income typically arises from dividend distributions.</xs:documentation>
                    <xs:documentation xml:lang="de">Beteiligungswertpapier (Aktie). Verbrieft eine Beteiligung an einer Kapitalgesellschaft und berechtigt den Inhaber zu Dividenden und Stimmrechten. Kapitalerträge entstehen typischerweise aus Gewinnausschüttungen.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="Bond">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Debt security (bond). Represents a creditor relationship with the issuer and entitles the holder to interest payments. Capital income typically arises from interest distributions.</xs:documentation>
                    <xs:documentation xml:lang="de">Schuldverschreibung (Anleihe). Verbrieft ein Gläubigerverhältnis gegenüber dem Emittenten und berechtigt den Inhaber zu Zinszahlungen. Kapitalerträge entstehen typischerweise aus Zinserträgen.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
            <xs:enumeration value="DepositaryReceipt">
                <xs:annotation>
                    <xs:documentation xml:lang="en">Depositary receipt (e.g. ADR, GDR). A certificate issued by a depositary bank representing shares of a foreign company held in custody. Capital income arises from the underlying dividend distributions of the foreign security.</xs:documentation>
                    <xs:documentation xml:lang="de">Hinterlegungsschein (z. B. ADR, GDR). Von einer Depotbank ausgestellte Urkunde, die im Depot gehaltene Aktien eines ausländischen Unternehmens verbrieft. Kapitalerträge entstehen aus den Ausschüttungen des zugrunde liegenden ausländischen Wertpapiers.</xs:documentation>
                </xs:annotation>
            </xs:enumeration>
        </xs:restriction>
    </xs:simpleType>

