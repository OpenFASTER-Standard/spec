<?xml version="1.0" encoding="utf-8"?>
<xs:schema targetNamespace="http://taxinfotransfer.org/tpd/1.0/ThirdPartyDisclosureRequest.xsd"
           xmlns="http://taxinfotransfer.org/tpd/1.0/ThirdPartyDisclosureRequest.xsd"
           xmlns:tpd="http://taxinfotransfer.org/tpd/1.0/ThirdPartyDisclosureRequest.xsd"
           xmlns:xs="http://www.w3.org/2001/XMLSchema"
           version="1.0"
           elementFormDefault="qualified">

<xs:element name="ThirdPartyDisclosureRequest">
		<xs:annotation>
			<xs:documentation xml:lang="en">Root element for disclosure of custodian accounts</xs:documentation>
			<xs:documentation xml:lang="de">Wurzelelement für Offenlegung von Steuerinformationen für B-Depots</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
                <xs:choice minOccurs="1" maxOccurs="unbounded">
                    <xs:element name="RequestMiKaDivReportingForIncome" type="RequestMiKaDivReportingForIncomeType"/>
                    <xs:element name="CancelMiKaDivReportingForIncome" type="CancelMiKaDivReportingForIncomeType"/>
                </xs:choice>                
			</xs:sequence>	
		</xs:complexType>		
	</xs:element>

	<xs:complexType name="RequestDisclosureType" abstract="true">
		<xs:annotation>
			<xs:documentation xml:lang="en">Base type for the disclosure. Not for direct use.</xs:documentation>
			<xs:documentation xml:lang="de">Basistyp für die Offenlegung. Nicht für die direkte Verwendung gedacht.</xs:documentation>
		</xs:annotation>
        
		<xs:sequence>
		</xs:sequence>
		
        <xs:attribute name="RequestId" type="UUIDType" use="required">
			<xs:annotation>
				<xs:documentation xml:lang="en">Unique identifier for the request. Must be unique even over subsequent files. To be defined by the customer institute.</xs:documentation>
				<xs:documentation xml:lang="de">Eindeutiger Identifier für die Anfrage. Muss auch über folgende Dateien eindeutig sein. Ist vom Kundeninstitut festzulegen.</xs:documentation>
			</xs:annotation>
		</xs:attribute>
		<xs:attribute name="Timestamp" type="xs:date" use="optional">
			<xs:annotation>
				<xs:documentation xml:lang="en">Timestamp of the submission of the request.</xs:documentation>
				<xs:documentation xml:lang="de">Zeitstempel der Übertragung der Anfrage.</xs:documentation>
			</xs:annotation>
		</xs:attribute>
		<xs:attribute name="AccountNumber" type="Name200Type" use="required">
			<xs:annotation>
				<xs:documentation xml:lang="en">Account number of the requesting custodian.</xs:documentation>
				<xs:documentation xml:lang="de">Kontonummer der anfragenden Verwahrstelle.</xs:documentation>
			</xs:annotation>
		</xs:attribute>
		<xs:attribute name="ClientReference" type="Name200Type" use="optional">
			<xs:annotation>
				<xs:documentation xml:lang="en">Custom reference data of the client.</xs:documentation>
				<xs:documentation xml:lang="de">Frei vergebbare Referenz des Kunden.</xs:documentation>
			</xs:annotation>
		</xs:attribute>
        <xs:attribute name="ClientContactpersonName" type="Name200Type" use="optional">
            <xs:annotation>
                <xs:documentation xml:lang="en">Name of the responsible foreign bank contact person.</xs:documentation>
                <xs:documentation xml:lang="de">Name Verantwortlicher Auslandsbank.</xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ClientContactpersonPhone" type="Name35Type" use="optional">
            <xs:annotation>
                <xs:documentation xml:lang="en">Telephone number of the responsible foreign bank contact person.</xs:documentation>
                <xs:documentation xml:lang="de">Tel-Nr Verantwortlicher Auslandsbank.</xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ClientContactpersonEmail" type="Name200Type" use="optional">
            <xs:annotation>
                <xs:documentation xml:lang="en">E-mail address of the responsible foreign bank contact person.</xs:documentation>
                <xs:documentation xml:lang="de">E-Mail Verantwortlicher Auslandsbank.</xs:documentation>
            </xs:annotation>
        </xs:attribute>
        
	</xs:complexType>

	<xs:complexType name="RequestMiKaDivReportingForIncomeType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Disclosure of a single capital income in Germany according to MiKaDiv §45b.</xs:documentation>
			<xs:documentation xml:lang="de">Offenlegung eines einzelnen Kapitalertrags in Deutschland gemäß MiKaDiv §45b.</xs:documentation>
		</xs:annotation>
        
		<xs:complexContent>
			<xs:extension base="RequestDisclosureType">
                
				<xs:sequence>
					<xs:element name="AccountOwnersAndRepresentative" type="AccountOwnersAndRepresentativeType" minOccurs="1"/>
					<xs:element name="Income" type="CapitalIncomeType" minOccurs="1"/>
					<xs:element name="CustodyChain" type="CustodyChainType" minOccurs="1"/>
                    <xs:choice minOccurs="1">
                        <xs:annotation>
                            <xs:documentation xml:lang="en">The receipts and deliveries need to be declared. Dependent on the requirements of the German paying agent this has to be done either with FiFo calculation applied or without.</xs:documentation>
                            <xs:documentation xml:lang="de">Die Zu- und Abgänge müssen deklariert werden. Abhängig von den Anforderungen der deutschen Zahlstelle müssen diese entweder mit oder ohne angewendete FiFo Berechnung angegeben werden.</xs:documentation>
                        </xs:annotation>
                        <xs:element name="ReceiptsAndDeliveriesFiFo" type="ReceiptsAndDeliveriesFiFoType"/>
                        <xs:element name="ReceiptsAndDeliveriesAll" type="ReceiptsAndDeliveriesAllType"/>
                    </xs:choice>
				</xs:sequence>
                
                <xs:attribute name="RequestedService" type="DisclosureRequestedServiceType" use="required" />
                <xs:attribute name="RequestedServiceReason" type="Name256Type" use="optional">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">Reason for the requested service, especially for correction or cancellation.</xs:documentation>
                        <xs:documentation xml:lang="de">Grund für die angefragte Leistung. Vor allem bei Korrektur oder Storno.</xs:documentation>
                    </xs:annotation>
                </xs:attribute>                
                <xs:attribute name="RequestedAttestationType" type="DisclosureRequestedAttestationType" use="optional" />
                <xs:attribute name="IsCorrectionRequest" type="xs:boolean" use="optional">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">A correction is to be performed for a report. The data record contains a reference to the preceding request.</xs:documentation>
                        <xs:documentation xml:lang="de">Für einen Report soll eine Korrektur durchgeführt werden. Der Datensatz enthält einen Verweis auf die vorhergehende Anfrage.</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="PreviousRequestIdForCorrection" type="UUIDType" use="optional">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">If the request is for correction of a previous request, then the RequestId of the previous request must be provided.</xs:documentation>
                        <xs:documentation xml:lang="de">Sofern die Anfrage der Berichtigung einer vorangegangenen Anfrage dient, ist die RequestId der vorangegangenen Anfrage anzugeben.</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="ReportSerialNumber" type="UUIDType" use="optional">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">Serial number (UUID) of an already submitted report, if provided previously by the German Paying agent. Used as a (additional) reference for correction.</xs:documentation>
                        <xs:documentation xml:lang="de">Ordnungsnummer (UUID) eines bereits übermittelten Datensatzes, sofern von der deutschen Zahlstelle bereitgestellt; dient als (zusätzliche) Referenz für die Berichtigung.</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="TaxCertificatePrintedContactpersonName" type="Name200Type" use="optional">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">Name of the contact person for the customer, printed on the tax certificate or cover letter.</xs:documentation>
                        <xs:documentation xml:lang="de">Name Ansprechpartner für Kunden (wird auf Steuerbescheinigung bzw. Anschreiben angedruckt).</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="TaxCertificatePrintedContactpersonPhone" type="Name35Type" use="optional">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">Telephone number of the contact person for the customer, printed on the tax certificate or cover letter.</xs:documentation>
                        <xs:documentation xml:lang="de">Tel-Nr Ansprechpartner für Kunden (wird auf Steuerbescheinigung bzw. Anschreiben angedruckt).</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="TaxCertificatePrintedContactpersonEmail" type="Name200Type" use="optional">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">E-mail address of the contact person for the customer, printed on the tax certificate or cover letter.</xs:documentation>
                        <xs:documentation xml:lang="de">E-Mail Ansprechpartner für Kunden (wird auf Steuerbescheinigung bzw. Anschreiben angedruckt).</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="TaxCertificateAlternativeRecipientName" type="Name200Type" use="optional">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">Name of the alternative mailing address recipient.</xs:documentation>
                        <xs:documentation xml:lang="de">Name der (abweichenden) Versandadresse.</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="TaxCertificateAlternativeRecipientAddress" type="Name256Type" use="optional">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">Address of the alternative mailing address recipient.</xs:documentation>
                        <xs:documentation xml:lang="de">Anschrift der (abweichenden) Versandadresse.</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="TaxCertificateAlternativeRecipientEmail" type="Name256Type" use="optional">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">E-mail address of the alternative mailing address recipient.</xs:documentation>
                        <xs:documentation xml:lang="de">E-mail der (abweichenden) Versandadresse.</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="EventType" type="Name20Type" use="optional" >
                    <xs:annotation>
                        <xs:documentation xml:lang="en">Event designations of the German paying agent according to ISO 20022.</xs:documentation>
                        <xs:documentation xml:lang="de">Eventbezeichnungen der Deutschen Zahlstelle nach ISO20022.</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="FundId" type="Name20Type" use="optional" >
                    <xs:annotation>
                        <xs:documentation xml:lang="en">Fund identifier (status certificate number).</xs:documentation>
                        <xs:documentation xml:lang="de">Ordnungsnummer des Fonds (Statusbescheinigungsnummer).</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>

    <xs:complexType name="CancelMiKaDivReportingForIncomeType">
        <xs:annotation>
            <xs:documentation xml:lang="en">Cancellation of a previous disclosure request.</xs:documentation>
            <xs:documentation xml:lang="de">Stornierung einer zuvor übermittelten Offenlegungsanfrage.</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="RequestDisclosureType">
                
                <xs:sequence>
                </xs:sequence>
                
                <xs:attribute name="PreviousRequestIdForCancellation" type="UUIDType" use="required">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">If the request is for cancellation of a previous request, then the RequestId of the previous request must be provided.</xs:documentation>
                        <xs:documentation xml:lang="de">Sofern die Anfrage der Stornierung einer vorangegangenen Anfrage dient, ist die RequestId der vorangegangenen Anfrage anzugeben.</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="ReportSerialNumber" type="UUIDType" use="optional">
                    <xs:annotation>
                        <xs:documentation xml:lang="en">Serial number (UUID) of an already submitted report, if provided previously by the German Paying agent. Used as a (additional) reference for cancellation.</xs:documentation>
                        <xs:documentation xml:lang="de">Ordnungsnummer (UUID) eines bereits übermittelten Datensatzes, sofern von der deutschen Zahlstelle bereitgestellt; dient als (zusätzliche) Referenz für die Storno.</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

	<xs:complexType name="AccountOwnersAndRepresentativeType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Defines the list of account persons.</xs:documentation>	
			<xs:documentation xml:lang="de">Liste der Konto-Personen.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="SecuritiesAccountNumber" type="Name200Type" minOccurs="1">
				<xs:annotation>
					<xs:documentation xml:lang="en">Account number of the tax voucher person at the custodian to whom the tax voucher person is directly contracted.</xs:documentation>
					<xs:documentation xml:lang="de">Depotnummer der bescheinigungsberechtigten Person bei derjenigen Verwahrstelle, zu der eine unmittelbare Vertragsbeziehung besteht.</xs:documentation>
				</xs:annotation>
			</xs:element>
            <xs:element name="AccountType" type="AccountTypeType" minOccurs="1" />
            <xs:element name="TaxCertificateReceiverPersons" minOccurs="1" maxOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">List of persons receiving the tax certificate.</xs:documentation>
                    <xs:documentation xml:lang="de">Aufzählung der Personen, die die Steuerbescheinigung erhalten.</xs:documentation>
                </xs:annotation>
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="TaxCertificateReceiverPerson" type="TaxCertificateReceiverPersonType" minOccurs="1" maxOccurs="2"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="ThirdPartyPersons" minOccurs="0" maxOccurs="1">
                <xs:annotation>
                    <xs:documentation xml:lang="en">List of third party persons. Must be completed if the account holder is not the beneficial owner AND if the beneficial owner gets disclosed. In this scenario information about the third party who is the account holder must be disclosed as well.</xs:documentation>
                    <xs:documentation xml:lang="de">Aufzählung der dritten Personen. Pflichtangabe, wenn der Kontoinhaber nicht der wirtschaftlich Berechtigte (Gläubiger der Kapitalerträge) ist und der wirtschaftlich Berechtigte offengelegt wird; in diesem Fall sind auch die Angaben zu dem Dritten als Kontoinhaber offenzulegen.</xs:documentation>
                </xs:annotation>
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="ThirdPartyPerson" type="ThirdPartyPersonType" minOccurs="1" maxOccurs="5"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
			<xs:element name="AccountRelationship" type="AccountRelationshipType" minOccurs="0" >
                <xs:annotation>
                    <xs:documentation xml:lang="en">If the tax voucher person is not the beneficial owner (creditor), then the account relationship has to be specified.</xs:documentation>
                    <xs:documentation xml:lang="de">Ist die bescheinigungsberechtigte Person nicht selbst Gläubiger der Kapitalerträge (wirtschaftlich Berechtigter), so ist das Depotverhältnis anzugeben.</xs:documentation>
                </xs:annotation>
            </xs:element>
		</xs:sequence>
	</xs:complexType>

    <xs:complexType name="TaxCertificateReceiverPersonType">
        <xs:annotation>
            <xs:documentation xml:lang="en">Type of a person receiving the tax certificate.</xs:documentation>
            <xs:documentation xml:lang="de">Personentyp für Empfänger der Steuerbescheinigung.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:choice>
                <xs:sequence>
                    <xs:element name="Individual" type="IndividualPersonType" minOccurs="1"/>
                    <xs:element name="IndividualPersonRegistrationAddress" type="TaxCertificateIndividualPersonAddressType" minOccurs="1" />
                    <xs:element name="IndividualPersonTaxIdentification" type="TaxCertificateIndividualPersonTaxIdentificationType" minOccurs="1"/>                    
                </xs:sequence>
                <xs:sequence>
                    <xs:element name="LegalPerson" type="LegalPersonType" minOccurs="1"/>
                    <xs:element name="LegalPersonRegistrationAddress" type="TaxCertificateLegalPersonAddressType"  minOccurs="1"/>
                    <xs:element name="LegalPersonTaxIdentification" type="TaxCertificateLegalPersonTaxIdentificationType" minOccurs="1"/>
                </xs:sequence>
                <xs:element name="Community" type="CommunityPersonType"/>
            </xs:choice>
            <xs:element name="Relationship" minOccurs="1">
                <xs:simpleType>
                    <xs:annotation>
                        <xs:documentation xml:lang="en">Indicate the role of the tax certificate receiver person.</xs:documentation>
                        <xs:documentation xml:lang="de">Angabe der Rolle der die Steuerbescheinigung empfangenden Person.</xs:documentation>
                    </xs:annotation>
                    <xs:restriction base="xs:string">
                        <xs:enumeration value="Creditor">
                            <xs:annotation>
                                <xs:documentation xml:lang="en">Creditor (beneficial owner).</xs:documentation>
                                <xs:documentation xml:lang="de">Gläubiger der Kapitalerträge (wirtschaftlich Berechtigter).</xs:documentation>
                            </xs:annotation>
                        </xs:enumeration>
                        <xs:enumeration value="AccountHolder">
                            <xs:annotation>
                                <xs:documentation xml:lang="en">Account holder (not the beneficial owner).</xs:documentation>
                                <xs:documentation xml:lang="de">Kontoinhaber (nicht wirtschaftlich Berechtigter).</xs:documentation>
                            </xs:annotation>
                        </xs:enumeration>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="ThirdPartyPersonType">
        <xs:annotation>
            <xs:documentation xml:lang="en">Third Party person type.</xs:documentation>
            <xs:documentation xml:lang="de">Personentyp Dritte.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:choice>
                <xs:sequence>
                    <xs:element name="Individual" type="IndividualPersonType" minOccurs="1" />
                    <xs:element name="IndividualPersonRegistrationAddress" type="ThirdPartyIndividualPersonAddressType" minOccurs="1" />
                    <xs:element name="IndividualPersonTaxIdentification" type="ThirdPartyIndividualPersonTaxIdentificationType" minOccurs="1" />
                </xs:sequence>
                <xs:sequence>
                    <xs:element name="LegalPerson" type="LegalPersonType" minOccurs="1"/>
                    <xs:element name="LegalPersonRegistrationAddress" type="ThirdPartyLegalPersonAddressType" minOccurs="1" />
                    <xs:element name="LegalPersonTaxIdentification" type="ThirdPartyLegalPersonTaxIdentificationType" minOccurs="1" />
                </xs:sequence>
            </xs:choice>
            <xs:element name="Relationship" minOccurs="1">
                <xs:simpleType>
                    <xs:annotation>
                        <xs:documentation xml:lang="en">If the account holder is not the beneficial owner, this category specifies, how the account holder represents the beneficial owner.</xs:documentation>
                        <xs:documentation xml:lang="de">Ist der Kontoinhaber nicht der wirtschaftlich Berechtigte, so ist hier anzugeben, in welcher Eigenschaft der Kontoinhaber den wirtschaftlich Berechtigten vertritt.</xs:documentation>
                    </xs:annotation>
                    <xs:restriction base="xs:string">
                        <xs:enumeration value="Trustee">
                            <xs:annotation>
                                <xs:documentation xml:lang="en">Trustee.</xs:documentation>
                                <xs:documentation xml:lang="de">Treuhänder.</xs:documentation>
                            </xs:annotation>
                        </xs:enumeration>
                        <xs:enumeration value="Pledgor">
                            <xs:annotation>
                                <xs:documentation xml:lang="en">Pledgor.</xs:documentation>
                                <xs:documentation xml:lang="de">Verpfänder (Pfandgeber).</xs:documentation>
                            </xs:annotation>
                        </xs:enumeration>
                        <xs:enumeration value="Grantor of usufruct">
                            <xs:annotation>
                                <xs:documentation xml:lang="en">Grantor of usufruct.</xs:documentation>
                                <xs:documentation xml:lang="de">Nießbrauchsbesteller.</xs:documentation>
                            </xs:annotation>
                        </xs:enumeration>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

	<xs:complexType name="PersonType" abstract="true">
		<xs:annotation>
			<xs:documentation xml:lang="en">Base type for a person. Not for direct use.</xs:documentation>	
			<xs:documentation xml:lang="de">Basistyp für eine Person. Nicht für direkte Verwendung gedacht.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
	
		</xs:sequence>
		<xs:attribute name="PersonIdentifier" type="Name45Type" use="optional">
			<xs:annotation>
				<xs:documentation xml:lang="en">Unique identifier for a person. Must be unique over subsequent files. For a subsequent request to the same person, the same identifier must be provided. To be defined by the customer institute.</xs:documentation>
				<xs:documentation xml:lang="de">Eindeutiger Identifier für eine Person. Muss auch über folgende Dateien eindeutig sein. Für eine spätere Anfrage zum selben Person muss der gleiche Identifier geliefert werden. Ist durch das Kundeninstitut festzulegen.</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>

	<xs:complexType name="IndividualPersonType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Natural person.</xs:documentation>
			<xs:documentation xml:lang="de">Natürliche Person.</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="PersonType">
				<xs:sequence>
					<xs:element name="Title" type="Name20Type" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation xml:lang="en">The person’s title if applicable.</xs:documentation>
                            <xs:documentation xml:lang="de">Akademischer Grad bzw. Titel der Person, soweit vorhanden.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
					<xs:element name="NamePrefix" type="Name20Type" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation xml:lang="en">The person’s name prefix if applicable.</xs:documentation>
                            <xs:documentation xml:lang="de">Namenszusatz vor dem Nachnamen (Präfix), soweit vorhanden.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
					<xs:element name="FirstName" type="Name45Type" minOccurs="1">
                        <xs:annotation>
                            <xs:documentation xml:lang="en">The person’s first name.</xs:documentation>
                            <xs:documentation xml:lang="de">Vorname der Person.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
					<xs:element name="LastName" type="Name45Type" minOccurs="1">
                        <xs:annotation>
                            <xs:documentation xml:lang="en">The person’s last name.</xs:documentation>
                            <xs:documentation xml:lang="de">Nachname (Familienname) der Person.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
					<xs:element name="NameAffix" type="Name20Type" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation xml:lang="en">The person’s name prefix if applicable.</xs:documentation>
                            <xs:documentation xml:lang="de">Namenszusatz nach dem Nachnamen (Affix), soweit vorhanden.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
					<xs:element name="DateOfBirth" type="DateOfBirthType" minOccurs="1" />
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>

	<xs:complexType name="LegalPersonType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Non natural person.</xs:documentation>
			<xs:documentation xml:lang="de">Nicht natürliche Person.</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="PersonType">
				<xs:sequence>
					<xs:element name="Name" type="Name256Type" minOccurs="1">
                        <xs:annotation>
                            <xs:documentation xml:lang="en">The name of the non-natural person.</xs:documentation>
                            <xs:documentation xml:lang="de">Name der nicht natürlichen Person (juristische Person bzw. Personengesellschaft).</xs:documentation>
                        </xs:annotation>
                    </xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>

    <xs:complexType name="CommunityPersonType">
        <xs:annotation>
            <xs:documentation xml:lang="en">Community of up to 10 persons.</xs:documentation>
            <xs:documentation xml:lang="de">Gemeinschaft von bis zu 10 Personen.</xs:documentation>
        </xs:annotation>
		<xs:sequence>
            <xs:element name="CommunityShareholder" minOccurs="1" maxOccurs="10">
                <xs:complexType>
                    <xs:choice>
                        <xs:sequence>
                            <xs:element name="Individual" type="IndividualPersonType" minOccurs="1"/>
                            <xs:element name="IndividualPersonRegistrationAddress" type="TaxCertificateIndividualPersonAddressType" minOccurs="1"/>
                            <xs:element name="IndividualPersonTaxIdentification" type="TaxCertificateIndividualPersonTaxIdentificationType" minOccurs="1"/>
                        </xs:sequence>
                        <xs:sequence>
                            <xs:element name="LegalPerson" type="LegalPersonType"/>
                            <xs:element name="LegalPersonRegistrationAddress" type="TaxCertificateLegalPersonAddressType" minOccurs="1"/>
                            <xs:element name="LegalPersonTaxIdentification" type="TaxCertificateLegalPersonTaxIdentificationType" minOccurs="1"/>
                        </xs:sequence>
                    </xs:choice>
                </xs:complexType>
            </xs:element>
		</xs:sequence>
    </xs:complexType>

	<xs:complexType name="AddressType">
		<xs:annotation>
			<xs:documentation xml:lang="en">Address.</xs:documentation>
			<xs:documentation xml:lang="de">Adresse.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="StreetOrPostalCode" type="Name80Type" minOccurs="0" >
                <xs:annotation>
                    <xs:documentation xml:lang="en">The street name of the address.</xs:documentation>
                    <xs:documentation xml:lang="de">Straßenbezeichnung der Anschrift.</xs:documentation>
                </xs:annotation>
