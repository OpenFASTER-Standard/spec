			<xs:documentation xml:lang="de">Europäischer einheitlicher Kennzeichner (EUID) im Sinne des Artikels 16 der Richtlinie (EU) 2017/1132.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="NameType">
