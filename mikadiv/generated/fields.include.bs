    <col style="width:82%">
  </colgroup>
  <thead><tr><th>Value<th>Meaning</tr></thead>
  <tbody>
    <tr><td><code>FiFo</code><td class="long">Receipts and deliveries are declared WITH FiFo calculation already applied by the submitter - fill the FIFO Trades sheet.</tr>
    <tr><td><code>All</code><td class="long">Receipts and deliveries are declared WITHOUT FiFo (the German paying agent applies FiFo) - fill the Raw Transactions All sheet.</tr>
  </tbody>
</table>

